# Public key hasil "npx web-push generate-vapid-keys" (boleh publik).
VAPID_PUBLIC_KEY=BBIEvHSjYzluVDkCCuRMUrIF9SrIupRQZzn0qJE_FXtgMByyxeWhp5rhzuLE6vT3RZagmHOX5aokzu6TPomAroE

# Private key — SALIN dari output terminal Debian. RAHASIA, jangan dibagikan.
VAPID_PRIVATE_KEY=GANTI_DENGAN_PRIVATE_KEY_DARI_TERMINAL

# Token rahasia; HARUS sama persis dengan gc_push_secret di report ABAP.
PUSH_SECRET=GANTI_DENGAN_SECRET_ACAK

# Opsional. Port 3000 sudah dipakai push-bridge -> notif-approval pakai 3002.
PORT=3002
VAPID_CONTACT=mailto:admin@pawindo.com
